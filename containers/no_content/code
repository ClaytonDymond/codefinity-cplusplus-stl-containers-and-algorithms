#include <iostream>
#include <vector>

std::vector<int> createSequence(int n)
{
    // Your code here
    std::vector<int> v;
    for (int i = 1; i <= n; i++)
        v.push_back(i);
    return v;
}

int sumVector(const std::vector<int>& vec)
{
    // Your code here
    int total = 0;
    for (auto it = vec.begin(); it != vec.end(); ++it)
        total += *it;
    return total;
}

int main()
{
    std::cout << sumVector(createSequence(25)) << std::endl;
    return 0;
}